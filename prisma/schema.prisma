// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  CONTRIBUTOR
  ADMIN
  SUPERADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  googleId          String?       @unique
  password          String?
  name              String        @db.VarChar(255)
  bio               String?
  image             String?
  gender            Gender?
  phoneNumber       String?
  country           String?
  state             String?
  careerPath        String?
  levelOfExperience String?
  referralMode      String?
  isSubscribed      Boolean       @default(false)
  isVerified        Boolean       @default(false)
  role              Role          @default(USER)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  tokens            Token[]
  events            Event[]
  blogPosts         BlogPost[]
  participants      Participant[]
  cohorts           Cohort[]
  teamMember        TeamMember?

  @@index([role])
}

enum TeamCategory {
  FOUNDER
  DESIGN_AND_PRODUCT
  COMMUNITY_MANAGEMENT
  ENGINEERING
  CONTENT_CREATION
  OTHERS
}

model TeamMember {
  id          String       @id @default(cuid())
  title       String
  category    TeamCategory
  twitterUrl  String?
  linkedInUrl String?
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([category])
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  INVITE_TEAM_MEMBER
}

model Token {
  id      String    @id @default(cuid())
  userId  String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token   String    @unique
  type    TokenType
  expires DateTime
}

model Event {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  thumbnailImage String
  description    String
  details        String
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  startDate      DateTime?
  endDate        DateTime?
  location       String
  creatorId      String
  creator        User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  eventImages    EventImage[]

  @@index([isPublished, publishedAt])
  @@index([creatorId, createdAt])
  @@index([deletedAt])
}

model EventImage {
  id       String @id @default(cuid())
  imageUrl String
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String
  thumbnailImage String
  content        String
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  author         User      @relation(fields: [authorId], references: [id])
  authorId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([isPublished, publishedAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model Cohort {
  id                String         @id @default(cuid())
  title             String         @db.VarChar(255)
  slug              String         @unique
  thumbnailImage    String
  description       String
  details           String
  startDate         DateTime
  endDate           DateTime
  isPublished       Boolean        @default(false)
  publishedAt       DateTime?
  classTime         String
  venue             String
  nftLiveStatus     Boolean        @default(false)
  whatsappGroupUrl  String
  nftCertificateUrl String?
  Participants      Participant[]
  cohortTickets     CohortTicket[]
  deletedAt         DateTime?
  creatorId         String
  creator           User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([isPublished, publishedAt])
  @@index([creatorId, createdAt])
  @@index([deletedAt])
}

model Participant {
  id             String        @id @default(cuid())
  walletAddress  String?
  nftClaimStatus Boolean       @default(false)
  cohort         Cohort        @relation(fields: [cohortId], references: [id])
  cohortId       String
  user           User          @relation(fields: [userId], references: [id])
  userId         String
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cohortTicket   CohortTicket?

  @@unique([cohortId, userId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model CohortTicket {
  id               String        @id @default(cuid())
  status           PaymentStatus @default(PENDING)
  amount           String
  trxRef           String        @unique
  owner            Participant   @relation(fields: [ownerId], references: [id])
  ownerId          String        @unique
  cohort           Cohort        @relation(fields: [cohortId], references: [id])
  cohortId         String
  idempotencyKey   String        @unique
  authorizationUrl String?
  initializedAt    DateTime?
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}
