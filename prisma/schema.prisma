// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  CONTRIBUTOR
  ADMIN
  SUPERADMIN
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  password          String?
  googleId          String?       @unique
  name              String        @db.VarChar(255)
  bio               String?
  image             String?
  gender            String?
  phoneNumber       String?
  country           String?
  state             String?
  careerPath        String?
  levelOfExperience String?
  referralMode      String?
  isSubscribed      Boolean       @default(false)
  isVerified        Boolean       @default(false)
  role              Role          @default(USER)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  tokens            Token[]
  events            Event[]
  blogPosts         BlogPost[]
  participants      Participant[]
  cohorts           Cohort[]

  @@index([role])
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

model Token {
  id      String    @id @default(cuid())
  userId  String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token   String    @unique @default(cuid())
  type    TokenType
  expires DateTime
}

model Event {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  thumbnailImage String
  description    String
  details        String
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  startDate      DateTime
  endDate        DateTime
  location       String
  creatorId      String
  creator        User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  eventImages    EventImage[]

  @@index([isPublished, publishedAt])
  @@index([creatorId, createdAt])
  @@index([deletedAt])
}

model EventImage {
  id       String @id @default(cuid())
  imageUrl String
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String
  thumbnailImage String
  content        String
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  author         User      @relation(fields: [authorId], references: [id])
  authorId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([isPublished, publishedAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model Cohort {
  id             String         @id @default(cuid())
  title          String         @db.VarChar(255)
  slug           String         @unique
  thumbnailImage String
  description    String
  details        String
  startDate      DateTime
  endDate        DateTime
  isPublished    Boolean        @default(false)
  publishedAt    DateTime?
  classTime      String
  venue          String
  nftLiveStatus  Boolean        @default(false)
  Participants   Participant[]
  cohortTickets  CohortTicket[]
  deletedAt      DateTime?
  creatorId      String
  creator        User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([isPublished, publishedAt])
  @@index([creatorId, createdAt])
  @@index([deletedAt])
}

model Participant {
  id             String        @id @default(cuid())
  walletAddress  String?
  nftClaimStatus Boolean       @default(false)
  cohort         Cohort        @relation(fields: [cohortId], references: [id])
  cohortId       String
  cohortTicket   CohortTicket?
  cohortTicketId String
  user           User          @relation(fields: [userId], references: [id])
  userId         String
}

model CohortTicket {
  id         String      @id @default(cuid())
  paidStatus Boolean     @default(false)
  amount     String
  trxRef     String      @unique
  owner      Participant @relation(fields: [ownerId], references: [id])
  ownerId    String      @unique
  cohort     Cohort?     @relation(fields: [cohortId], references: [id])
  cohortId   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}
